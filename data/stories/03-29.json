  "title": "Eram três",
  "author": "António Torrado",
  "illustrator": "Cristina Malaquias",
  "textSegments": [
    {
      "layer": "html-layer-2",
      "paragraphs": [
        "São três bonecos de barro,",
        "três jaquetas, três bonés,",
        "três calças brancas, lavadas,",
        "com risquinha até aos pés.",
        "São três bonecos de barro,",
        "três bigodes de entremez ,",
        "três pencas de pêra parda,",
        "pintadas de camoês ."
      ]
    },
    {
      "layer": "html-layer-3",
      "paragraphs": [
        "São três bonecos de barro,",
        "três laços de azul francês,",
        "colarinhos cartonados,",
        "mudados de mês a mês.",
        "São três bonecos de barro",
        "muito graves todos três.",
        "Usam polainas de estado",
        "e calçam quarenta e três."
      ]
    },
    {
      "layer": "html-layer-4",
      "paragraphs": [
        "São três bonecos de barro",
        "em bizarra rigidez.",
        "Com garbo , diz-se um morgado,",
        "outro conde, outro marquês.",
        "São três bonecos de barro,",
        "de barro, digo outra vez,",
        "Na prateleira aprumados,",
        "mas ocos de altivez."
      ]
    },
    {
      "layer": "html-layer-5",
      "paragraphs": [
        "São três bonecos de barro,",
        "três jaquetas, três bonés,",
        "Pintados e repintados",
        "cada um vale por dez...",
        "Pois são três bonecos de barro,",
        "mas veio o gato Iniguês",
        "e num salto desastrado",
        "em cacos de telha os fez."
      ]
    },
    {
      "layer": "html-layer-6",
      "paragraphs": [
        "Eram três bonecos de barro,",
        "com apito rés aos pés.",
        "Dantes, ainda apitavam.",
        "Agora: é o que vês..."
      ]
    }
  ],
